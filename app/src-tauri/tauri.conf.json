{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lazy Cherry Pick",
  "version": "0.9.0",
  "identifier": "com.lazycherrypick.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Lazy Cherry Pick",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVENkMzOEU4MEU0M0ZDN0MKUldSOC9FTU82RGhzN2NZRk5SSEN1czc0SnNrcWlobDRheHd1NUJqejI2VkNNbmVrMlBhaHdTK1oK",
      "endpoints": [
        "https://github.com/tentaikhoan24/lazy-cherry-pick/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
